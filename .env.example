# Los agentes usan el primer provider disponible en este orden:
# Groq → Cerebras → Google Gemini
# Solo necesitás AL MENOS uno de los tres.

# Groq (gratis, más rápido): https://console.groq.com/keys
GROQ_API_KEY=gsk_tu-key-aqui

# Cerebras (gratis, similar a Groq): https://console.cerebras.ai/
CEREBRAS_API_KEY=csk_tu-key-aqui

# Google Gemini (gratis, fallback): https://aistudio.google.com/
GOOGLE_AI_API_KEY=tu-key-aqui

# Magnific MCP (imagenes profesionales IA — OPCIONAL): https://mcp.magnific.com
# Si no se setea, usa Pollinations.ai (gratis, sin key) como fallback automatico
MAGNIFIC_API_KEY=tu-key-aqui-opcional
